# Erforderlich: PostgreSQL-Verbindungsstring (Neon Serverless)
# Beispiel: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: Resend API-Key für E-Mail-Benachrichtigungen bei neuen Leads
# Ohne diesen Key funktioniert die App normal, aber ohne E-Mail-Benachrichtigungen
RESEND_API_KEY=
